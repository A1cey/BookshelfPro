<?xml version="1.0" encoding="UTF-8"?>
<FindBugsFilter
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xmlns="https://github.com/spotbugs/filter/3.0.0"
        xsi:schemaLocation="https://github.com/spotbugs/filter/3.0.0
            https://raw.githubusercontent.com/spotbugs/spotbugs/master/spotbugs/etc/findbugsfilter.xsd">

    <!-- Interfaces injected via constructor cannot expose mutable state -->
    <Match>
        <Bug pattern="EI_EXPOSE_REP2"/>
        <Or>
            <Class name="~.*Service"/>
            <Class name="~.*UseCase"/>
            <Class name="~.*Request"/>
        </Or>
    </Match>

    <!--    &lt;!&ndash; jMolecules byte-buddy instrumented classes can trigger false positives &ndash;&gt;-->
    <!--    <Match>-->
    <!--        <Class name="~.*_Accessor_.*"/>-->
    <!--    </Match>-->

    <!--    &lt;!&ndash; Records: SpotBugs sometimes misreads record accessor nullability &ndash;&gt;-->
    <!--    <Match>-->
    <!--        <Bug pattern="NP_NULL_ON_SOME_PATH_FROM_RETURN_VALUE"/>-->
    <!--        <Class name="~.*Record.*"/>-->
    <!--    </Match>-->

    <!--    &lt;!&ndash; Test code: relax some rules &ndash;&gt;-->
    <!--    <Match>-->
    <!--        <Class name="~.*Test"/>-->
    <!--        <Bug pattern="ST_WRITE_TO_STATIC_FROM_INSTANCE_METHOD"/>-->
